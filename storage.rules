rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    match /{allPaths=**} {
      // Allow public read access to images and assets
      allow read: if true;
      
      // Restrict write access only to the designated administrator
      allow write: if request.auth != null && request.auth.token.email == 'anitha.gunthala1999@gmail.com';
    }
  }
}
