rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Allow public read access to content configuration documents
    match /content/{document} {
      allow read: if true;
    }
    
    // Admin root rule: Allow full read/write access to all collections/documents for the admin
    match /{document=**} {
      allow read, write: if request.auth != null && request.auth.token.email == 'admin.procyonsolutions@gmail.com';
    }
  }
}
