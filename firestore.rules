rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Rules for public content configurations (e.g., website_data)
    match /content/{document} {
      // Allow read access to anyone so the public website loads properly
      allow read: if true;
      
      // Allow write access only to the designated administrator
      allow write: if request.auth != null && request.auth.token.email == 'anitha.gunthala1999@gmail.com';
    }
    
    // Safe default: deny all other collections unless explicitly allowed
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
